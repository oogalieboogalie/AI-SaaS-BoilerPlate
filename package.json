{
  "name": "ai-saas-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready AI-SaaS boilerplate with Next.js, Supabase, TypeScript, and Tailwind",
  "private": true,
  "scripts": {
    "dev": "npm run validate:env && next dev",
    "build": "npm run validate:env && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "validate:env": "node scripts/validate-env.js",
    "db:generate": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > types/supabase.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "docker:build": "docker build -t ai-saas-boilerplate .",
    "docker:run": "docker run -p 3000:3000 --env-file .env.local ai-saas-boilerplate",
    "deploy:vercel": "vercel --prod",
    "setup": "npm install && npm run validate:env",
    "health": "curl -f http://localhost:3000/api/health || exit 1"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.0.18",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.1.2",
    "@stripe/stripe-js": "^2.2.0",
    "@supabase/auth-helpers-nextjs": "^0.8.7",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.38.4",
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^20.10.4",
    "autoprefixer": "^10.4.16",
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.294.0",
    "next": "^15.5.4",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.32",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.48.2",
    "sonner": "^2.0.7",
    "stripe": "^14.7.0",
    "tailwind-merge": "^2.1.0",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^16.3.1",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.5.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "supabase": "^1.127.4",
    "uuid": "^9.0.1",
    "vitest": "^3.2.4"
  }
}
